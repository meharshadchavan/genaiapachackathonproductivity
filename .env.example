# Environment Variables for Multi-Agent Productivity Assistant
# Copy this file to .env and fill in your values. NEVER commit .env to Git!

# ── Firestore Persistence ────────────────────────────────────────────────────
# Set to true to enable Firestore storage when credentials are available.
USE_FIRESTORE=true

# If running locally, set the path to your service account JSON file.
# Cloud Run normally uses an attached service account and does not require this.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Runtime Configuration ────────────────────────────────────────────────────
PORT=8080

# Optional: if your deployment requires an explicit project ID.
# FIRESTORE_PROJECT_ID=your_gcp_project_id

# Environment Variables for Multi-Agent Productivity Assistant
# Copy this file to .env and fill in your values. NEVER commit .env to Git!

# ── Google Gemini / Vertex AI ────────────────────────────────────────────────
# Get your API key from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ── Google Cloud Platform ────────────────────────────────────────────────────
PROJECT_ID=your_gcp_project_id
REGION=us-central1

# ── AlloyDB (Phase 3 - Vector Memory) ───────────────────────────────────────
ALLOYDB_CLUSTER_ID=your_alloydb_cluster_id
ALLOYDB_INSTANCE_ID=your_alloydb_instance_id
ALLOYDB_DATABASE=productivity_db
ALLOYDB_USER=your_db_user
ALLOYDB_PASSWORD=your_db_password

# ── FastAPI Server ───────────────────────────────────────────────────────────
PORT=8080
